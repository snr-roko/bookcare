{
  "expo": {
    "name": "bookcare",
    "slug": "bookcare",
    "version": "1.0.0",
    "scheme": "bookcare",
    "orientation": "portrait",
    "icon": "./assets/bookcare-app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bookcare-app-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.snrroko.bookcare"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/bookcare-splash-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF3E0",
          "dark": {
            "image": "./assets/bookcare-splash-dark.png",
            "backgroundColor": "#8d4a1a"
          }
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f8f18b9-d7f4-4981-b0a5-2e641ab87f1e"
      }
    },
    "owner": "mr-roko"
  }
}
